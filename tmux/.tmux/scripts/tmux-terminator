#!/usr/bin/env bash

# Inherits theme + base layout from $FZF_DEFAULT_OPTS_FILE (set in zsh/.zshrc).
# Overrides only the chrome specific to this picker.
export FZF_DEFAULT_OPTS="\
    --layout=reverse \
    --border=top \
    --border-label=\"Kill session\" \
    --border-label-pos=1 \
    --no-info \
    --no-scrollbar \
    --prompt=\"   \""

for s in $(tmux list-sessions -F \#S | fzf); do
    tmux kill-session -t "$s"
done
