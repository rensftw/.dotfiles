################################################################################
# Aliases and shell functions
################################################################################

# Include work-related aliases, if the file exists
if [[ -f "$HOME/.aliases.work" ]]; then
    source "$HOME/.aliases.work"
fi

# Import ANSI escape codes for colors
if [[ -f "$DOTFILES_LOCATION/_scripts/colors.sh" ]]; then
    source "$DOTFILES_LOCATION/_scripts/colors.sh"
fi

# Source all alias modules in order.
# Files are numbered NN-name.sh to enforce load order via glob sort.
# Gaps (00, 20, 30, 40) leave room for future additions.
# shellcheck disable=SC1073,SC1036,SC1058,SC1072
for f in "$HOME/.aliases.d"/*.sh(N); do
    source "$f"
done
unset f
